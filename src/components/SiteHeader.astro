---
import { site } from '../site';
import Wordmark from './Wordmark.astro';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
function isActive(href: string) {
  const clean = (href.split('#')[0] ?? '').replace(/\/$/, '');
  if (!clean) return false;
  return path === clean || path.startsWith(`${clean}/`);
}
---

<header class="site-header">
  <div class="container site-header__inner">
    <Wordmark />
    <nav class="nav" aria-label="Primary">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={['nav__link', { 'is-active': isActive(item.href) }]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--c-hair);
  }
  .site-header__inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    padding-block: var(--space-md);
  }
  .nav {
    display: flex;
    gap: clamp(1.1rem, 4vw, 2.25rem);
  }
  .nav__link {
    font-size: var(--text-small);
    color: var(--c-stone);
    padding-block: 0.15rem;
    position: relative;
    transition: color var(--dur-fast) var(--ease-out);
  }
  /* Invisible hit-area expansion: lifts the tap target to ~44px without
     moving the text or the underline indicator. */
  .nav__link::before {
    content: '';
    position: absolute;
    inset-block: -0.6rem;
    inset-inline: -0.35rem;
  }
  .nav__link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 100%;
    bottom: -0.1rem;
    height: 1px;
    background: var(--c-accent);
    transition: right var(--dur) var(--ease-out);
  }
  .nav__link:hover {
    color: var(--c-ink);
  }
  .nav__link.is-active {
    color: var(--c-ink);
  }
  .nav__link.is-active::after,
  .nav__link:hover::after {
    right: 0;
  }
</style>
