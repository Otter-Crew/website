---
interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  // h2 when the row sits directly under a page <h1> (the /blog list); h3 when
  // it sits under a section heading (the homepage "Recent writing" section).
  headingLevel?: 2 | 3;
}
const { title, description, slug, pubDate, headingLevel = 2 } = Astro.props;
const Title = headingLevel === 3 ? 'h3' : 'h2';
const date = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const iso = pubDate.toISOString().slice(0, 10);
---

<li class="post">
  <div class="post__meta">
    <time datetime={iso}>{date}</time>
  </div>
  <div class="post__body">
    <Title class="post__title">
      <a class="post__link" href={`/blog/${slug}/`}>
        <span>{title}</span>
        <span class="arrow" aria-hidden="true">&rarr;</span>
      </a>
    </Title>
    <p class="post__desc">{description}</p>
  </div>
</li>

<style>
  .post {
    position: relative;
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: var(--space-md) var(--space-lg);
    padding-block: var(--space-lg);
    border-top: 1px solid var(--c-hair);
  }
  .post:last-child {
    border-bottom: 1px solid var(--c-hair);
  }
  .post__meta {
    padding-top: var(--space-2xs);
    font-size: var(--text-small);
    color: var(--c-stone);
  }
  .post__title {
    font-size: var(--text-h2);
    font-weight: 420;
  }
  .post__link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5em;
    color: inherit;
    transition: color var(--dur-fast) var(--ease-out);
  }
  /* Stretch the title link across the whole row so the entire ledger row is
     the click target, while the link's accessible name stays just the title. */
  .post__link::after {
    content: '';
    position: absolute;
    inset: 0;
  }
  .post__link .arrow {
    color: var(--c-stone);
    font-size: 0.8em;
    transition:
      transform var(--dur) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
  }
  .post__desc {
    margin-top: var(--space-2xs);
    max-width: 56ch;
    line-height: 1.6;
    color: var(--c-ink-soft);
  }
  .post__link:hover {
    color: var(--c-accent);
  }
  .post__link:hover .arrow {
    color: var(--c-accent);
    transform: translateX(0.3em);
  }

  @media (max-width: 38rem) {
    .post {
      grid-template-columns: 1fr;
      gap: var(--space-2xs);
    }
  }
</style>
