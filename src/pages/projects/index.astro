---
import { getCollection, render } from 'astro:content';
import PageHeader from '../../components/PageHeader.astro';
import ProjectItem from '../../components/ProjectItem.astro';
import Prose from '../../components/Prose.astro';
import Section from '../../components/Section.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order || b.data.year - a.data.year);

// Render each project's Markdown body so the list can show the full content
// inline, not just the frontmatter summary.
const entries = await Promise.all(
  projects.map(async (p) => ({
    data: p.data,
    Content: (await render(p)).Content,
  })),
);
---

<BaseLayout
  title="Work"
  description="Projects and consulting engagements from otter-crew."
>
  <PageHeader
    marker="Work"
    title="Things built and rebuilt."
    lede="A few of the projects and engagements that say the most about how I work. Each is a study in making a system legible again."
  />

  <Section top="md" bottom="xl">
    <ul role="list">
      {
        entries.map(({ data, Content }) => (
          <ProjectItem
            title={data.title}
            year={data.year}
            status={data.status}
            role={data.role}
            link={data.link}
            expanded
          >
            <Prose>
              <Content />
            </Prose>
          </ProjectItem>
        ))
      }
    </ul>
  </Section>
</BaseLayout>
